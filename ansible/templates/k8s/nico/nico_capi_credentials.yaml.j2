apiVersion: v1
data:
  client_id: bmljby1hcGk=
  client_secret: bmljby1sb2NhbC1zZWNyZXQ=
  password: YWRtaW5wYXNzd29yZA==
  username: YWRtaW5AZXhhbXBsZS5jb20=
kind: Secret
metadata:
  annotations:
  labels:
    external-secrets.io/type: webhook
  name: nico-credentials
  namespace: platform-admin
type: Opaque
---
apiVersion: external-secrets.io/v1
kind: ClusterSecretStore
metadata:
  name: nico-credentials-webhook
spec:
  provider:
    webhook:
      # Keycloak OIDC token endpoint:
      # http://<host>:8082/realms/<realm>/protocol/openid-connect/token
      url: "{{ nico_token_url }}"
      method: POST
      headers:
        Content-Type: application/x-www-form-urlencoded
      # Password grant. For client_credentials, drop username/password
      # and set grant_type=client_credentials.
      body: "{% raw %}client_id={{ .kc.client_id }}&client_secret={{ .kc.client_secret }}&grant_type=password&username={{ .kc.username }}&password={{ .kc.password }}{% endraw %}"
      result:
        jsonPath: "$.access_token"
      secrets:
        - name: kc
          secretRef:
            name: nico-credentials
            namespace: platform-admin
---
apiVersion: external-secrets.io/v1
kind: ClusterExternalSecret
metadata:
  annotations:
  name: nico-credentials
spec:
  externalSecretName: nico-credentials
  externalSecretSpec:
    data:
    - remoteRef:
        conversionStrategy: Default
        decodingStrategy: None
        key: secret
        metadataPolicy: None
        nullBytePolicy: Ignore
      secretKey: AccessToken
    refreshInterval: 30s
    secretStoreRef:
      kind: ClusterSecretStore
      name: nico-credentials-webhook
    target:
      creationPolicy: Owner
      deletionPolicy: Retain
      name: nico-token
  namespaces:
  - tenant-a
  - tenant-b
