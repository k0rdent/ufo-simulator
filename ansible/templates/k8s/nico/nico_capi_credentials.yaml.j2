# SecretStore — POSTs the password grant to Keycloak,
# extracts $.access_token from the JSON response.
apiVersion: external-secrets.io/v1
kind: SecretStore
metadata:
  name: keycloak-token-store
  namespace: {{ nico_capi_provider_namespace }}
spec:
  provider:
    webhook:
      url: "{{ nico_token_url }}"
      method: POST
      headers:
        Content-Type: application/x-www-form-urlencoded
      body: "{% raw %}client_id={{ .kc.client_id }}&client_secret={{ .kc.client_secret }}&grant_type=password&username={{ .kc.username }}&password={{ .kc.password }}{% endraw %}"
      result:
        jsonPath: "$.access_token"
      secrets:
        - name: kc
          secretRef:
            name: {{ nico_credentials_secret_name }}
            key: client_id
---
# ExternalSecret — materializes the Secret the CarbideCluster IdentityRef points at.
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: carbide-access-token
  namespace: {{ nico_capi_provider_namespace }}
spec:
  refreshInterval: 1m
  secretStoreRef:
    name: keycloak-token-store
    kind: SecretStore
  target:
    name: {{ nico_capi_identity_secret_name }}
    creationPolicy: Owner
    template:
      type: Opaque
      data:
        AccessToken: "{% raw %}{{ .token }}{% endraw %}"
  data:
    - secretKey: token
      remoteRef:
        key: keycloak
