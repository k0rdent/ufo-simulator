# ClusterSecretStore — POSTs the password grant to Keycloak and extracts
# $.access_token. Cluster-scoped so ExternalSecrets in any namespace can
# reference it.
apiVersion: external-secrets.io/v1
kind: ClusterSecretStore
metadata:
  name: keycloak-token-store
spec:
  provider:
    webhook:
      url: "{{ nico_token_url }}"
      method: POST
      headers:
        Content-Type: application/x-www-form-urlencoded
      body: "{% raw %}client_id={{ .kc.client_id }}&client_secret={{ .kc.client_secret }}&grant_type=password&username={{ .kc.username }}&password={{ .kc.password }}{% endraw %}"
      result:
        jsonPath: "$.access_token"
      secrets:
        - name: kc
          secretRef:
            name: {{ nico_credentials_secret_name }}
            namespace: {{ nico_capi_provider_namespace }}
{% for namespace in nico_capi_identity_secret_namespaces %}
---
# ExternalSecret — materializes {{ nico_capi_identity_secret_name }} for NicoCluster IdentityRef.
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: nico-access-token
  namespace: {{ namespace }}
spec:
  refreshInterval: 1m
  secretStoreRef:
    name: keycloak-token-store
    kind: ClusterSecretStore
  target:
    name: {{ nico_capi_identity_secret_name }}
    creationPolicy: Owner
    template:
      type: Opaque
      data:
        AccessToken: "{% raw %}{{ .token }}{% endraw %}"
  data:
    - secretKey: token
      remoteRef:
        key: keycloak
{% endfor %}
