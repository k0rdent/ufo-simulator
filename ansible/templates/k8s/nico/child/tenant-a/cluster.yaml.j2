---
# Source: capm3-standalone-cp/templates/cluster.yaml
apiVersion: cluster.x-k8s.io/v1beta1
kind: Cluster
metadata:
  name: tenant-a-cluster
  namespace: tenant-a
spec:
  clusterNetwork:
    apiServerPort: 6443
    pods:
      cidrBlocks:
      - 10.243.0.0/16
    services:
      cidrBlocks:
      - 10.95.0.0/16
  controlPlaneEndpoint:
    host: 10.11.0.250
    port: 6443
  controlPlaneRef:
    apiVersion: controlplane.cluster.x-k8s.io/v1beta1
    kind: K0smotronControlPlane
    name: tenant-a-cluster-cp
    namespace: tenant-a
  infrastructureRef:
    apiVersion: infrastructure.cluster.x-k8s.io/v1beta2
    kind: CarbideCluster
    name: tenant-a-cluster
    namespace: tenant-a
---
apiVersion: infrastructure.cluster.x-k8s.io/v1beta2
kind: CarbideCluster
metadata:
  name: tenant-a-cluster
  namespace: tenant-a
spec:
  identityRef:
    name: carbide-credentials              # -> Secret above
    orgId: {{ nico_api_org }}
    apiEndpoint: {{ nico_api_base_url }}
    siteId: {{ nico_site_id }}
---
apiVersion: infrastructure.cluster.x-k8s.io/v1beta2
kind: CarbideMachine
metadata:
  name: tenant-a-cluster-machine-0
  namespace: tenant-a
  labels:
    cluster.x-k8s.io/cluster-name: tenant-a-cluster
    ufo.mirantis.com/networkbundle: test
spec:
  instanceTypeId: {{ nico_instance_type_id }}
  tenantId: {{ nico_tenant_id }}
  vpcId: {{ nico_vpc_id }}
  operatingSystemId: {{ nico_operating_system_id }}
  sshKeyGroupIds:
{% for ssh_key_group_id in nico_ssh_key_group_ids %}
    - {{ ssh_key_group_id }}
{% endfor %}
---
apiVersion: infrastructure.cluster.x-k8s.io/v1beta2
kind: CarbideNetworkConfig
metadata:
  name: tenant-a-cluster-machine-0
  namespace: tenant-a
spec:
  interfaces:
    - vpcPrefixId: {{ nico_vpc_prefix_id }}
      isPhysical: true
---
apiVersion: controlplane.cluster.x-k8s.io/v1beta1
kind: K0smotronControlPlane
metadata:
  name: tenant-a-cluster-cp
  namespace: tenant-a
spec:
  version: v1.31.1-k0s.0          # k0s version
  replicas: 1                      # 3 for HA
  service:
    type: LoadBalancer             # or NodePort if no LB
  persistence:
    type: emptyDir
---
apiVersion: bootstrap.cluster.x-k8s.io/v1beta1
kind: K0sWorkerConfig
metadata:
  name: tenant-a-cluster-machine-0
  namespace: tenant-a
spec:
  version: v1.31.1+k0s.0
---
apiVersion: cluster.x-k8s.io/v1beta2
kind: Machine
metadata:
  name: tenant-a-cluster-machine-0
  namespace: tenant-a
  labels:
    cluster.x-k8s.io/cluster-name: tenant-a-cluster
spec:
  clusterName: tenant-a-cluster
  version: v1.31.1
  bootstrap:
    configRef:
      apiGroup: bootstrap.cluster.x-k8s.io
      kind: K0sWorkerConfig
      name: tenant-a-cluster-machine-0
  infrastructureRef:
    apiGroup: infrastructure.cluster.x-k8s.io
    kind: CarbideMachine
    name: tenant-a-cluster-machine-0
