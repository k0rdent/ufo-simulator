diff --git a/deploy/k8s/k0r-tools/provision-apply.yaml b/deploy/k8s/k0r-tools/provision-apply.yaml
index 474e05af5..de752a877 100644
--- a/deploy/k8s/k0r-tools/provision-apply.yaml
+++ b/deploy/k8s/k0r-tools/provision-apply.yaml
@@ -37,6 +37,8 @@ spec:
       restartPolicy: Never
       # The tool only calls the platform's own HTTP APIs — no K8s API access.
       automountServiceAccountToken: false
+      imagePullSecrets:
+        - name: ghcr-pull-secret
       # Hardened pod context: run as the image's non-root user (uid 65532, set
       # in build/Dockerfile.go-tools) and apply the default seccomp profile.
       securityContext:
@@ -54,8 +56,8 @@ spec:
           # For a real cluster, pin a published tag here. For kind, build and load it
           # locally (`make docker-build-k0r-tools`, then `kind load
           # docker-image k0r-tools:latest`) — IfNotPresent keeps the loaded image.
-          image: k0r-tools:latest
-          imagePullPolicy: IfNotPresent
+          image: registry.ci.mirantis.com/k0rdent-apis/images/k0r-tools:main
+          imagePullPolicy: Always
           # The image bundles multiple tool binaries (no ENTRYPOINT); select
           # the provision tool explicitly.
           command: ["/usr/local/bin/provision"]
@@ -82,11 +84,11 @@ spec:
               value: "http://kong-internal:8100"
             # --- manifest secret refs: add one entry per {env: NAME} in the
             # manifest, sourced from your env's Secret. Example:
-            # - name: VENDOR_IDP_CLIENT_SECRET
-            #   valueFrom:
-            #     secretKeyRef:
-            #       name: provision-manifest-secrets
-            #       key: VENDOR_IDP_CLIENT_SECRET
+            - name: KINDMOCK_IDP_SECRET
+              valueFrom:
+                secretKeyRef:
+                  name: provision-manifest-secrets
+                  key: KINDMOCK_IDP_SECRET
           volumeMounts:
             - name: manifest
               mountPath: /etc/provision
