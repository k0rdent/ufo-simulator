+    # ── Infrastructure server sub-resources (KCS-678 companion) ──
+    # The ProvisionReservations child workflow (services/workflow/cmd/
+    # workflow-worker/workflows/child-workflows/management-apis/infrastructure/
+    # provision_reservation.go), invoked by instance-group-create (KCS-932,
+    # `provision-hosts` step; sole caller today — cluster-deployment-create-v3
+    # only reads server PSD, it doesn't patch it), hits three server-scoped
+    # endpoints on the infrastructure service after the reservation lands:
+    #   1. PATCH /servers/{slug}/providerSpecificData   (write NIC interfaces)
+    #   2. POST  /servers/{slug}/cloudConfig            (write node cloud-config)
+    #   3. GET   /servers/{slug}                        (poll provisioning state)
+    # All three are dual-auth in the Go handler (services/infrastructure/cmd/
+    # infrastructure/routes.go:210-221; endpoints introduced in KCS-678 / #565)
+    # but their internal-listener companion was never added. Worker calls fall
+    # through to the external `infrastructure` route (path prefix ~/.../servers,
+    # above) whose k0rdent-authz runs in listener_mode=external and 403s the
+    # client_credentials service JWT (no k0r claim — the Keycloak SPI
+    # deliberately skips svc-* clients per K0rdentClaimEnricher.java:190-194).
+    #
+    # Dual-auth via a Host filter: the SAME three paths need to serve BOTH the
+    # worker (internal listener, service JWT, InternalOnly middleware) AND
+    # external operators (public gateway, user JWT, RBAC via
+    # infrastructure.resources.read/update). The k0rdent-authz plugin's
+    # listener_mode is binary, so one route can't do both. We ship an internal
+    # route ALONGSIDE the existing external `infrastructure` route: both match
+    # the same paths, but the internal route carries a Host filter so it ONLY
+    # matches requests to Host: kong-internal(:8100) — which is how every
+    # internal caller in the repo reaches Kong (deploy/helm/charts/services/*/
+    # values.yaml WORKFLOW_API_ENDPOINT / INTERNAL_API_BASE_URL). External
+    # users hit a different Host and fall through to the external route.
+    #
+    # No routePriority is needed. Kong ranks routes with a Host filter above
+    # equivalent routes without one when the Host matches, so the worker's
+    # calls (Host: kong-internal) hit the internal route and external users
+    # (Host: <public gateway>) hit the external route deterministically
+    # without any regex_priority tiebreaker.
+    #
+    # Defense-in-depth: the plugin's listener_mode=internal +
+    # internal_listener_port gate stays in front. A spoofed Host: kong-internal
+    # on the external port still 403s with "wrong listener" — the Host filter
+    # is only for route disambiguation, not the security boundary.
+    infrastructure-server-subresources:
+      service: infrastructure
+      paths:
+        - ~/v1/regions/{{ .Values.global.region | default "local" }}/infrastructure/servers/[^/]+/providerSpecificData$
+        - ~/v1/regions/{{ .Values.global.region | default "local" }}/infrastructure/servers/[^/]+/cloudConfig$
+        - ~/v1/regions/{{ .Values.global.region | default "local" }}/infrastructure/servers/[^/]+$
+      # Kong strips the port when comparing Host, so `kong-internal` matches
+      # `kong-internal:8100`. FQDN forms are included defensively for future
+      # cross-namespace / fully-qualified callers.
+      internalHosts:
+        - kong-internal
+        - "kong-internal.{{ .Release.Namespace }}"
+        - "kong-internal.{{ .Release.Namespace }}.svc.cluster.local"
+      authz:
+        allowedCallers:
+          - 'svc-{{ .Values.global.region | default "local" }}-workflow-worker'
     # ── Workflow (services/workflow/cmd/workflow/routes.go:56-63) ──
